{
  "manifest_version": 3,
  "name": "Dark Pattern Scanner",
  "version": "1.0",
  "description": "Detects dark patterns on websites using AI",

  "permissions": ["activeTab", "scripting"],

  "host_permissions": [
  "http://127.0.0.1:8000/*",
  "http://localhost:8000/*"
],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}